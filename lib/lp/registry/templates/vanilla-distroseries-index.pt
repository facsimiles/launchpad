<html xmlns="http://www.w3.org/1999/xhtml"
  xmlns:tal="http://xml.zope.org/namespaces/tal"
  xmlns:metal="http://xml.zope.org/namespaces/metal"
  xmlns:i18n="http://xml.zope.org/namespaces/i18n" metal:use-macro="view/macro:page/main_only" i18n:domain="launchpad">
  <head>
    <metal:block fill-slot="head_epilogue">
      <link type="text/css" rel="stylesheet" tal:attributes="href string:${icingroot}/vanilla/pages/distroseries.css" />
      <script type="module" tal:attributes="src string:${view/combo_url}/?lp/app/javascript/vanilla/tabs-min.js"></script>
    </metal:block>
  </head>
  <body>
    <tal:breadcrumbs metal:fill-slot="breadcrumbs">
      <div class="row">
        <nav class="p-breadcrumbs" aria-label="Breadcrumbs">
          <ol class="p-breadcrumbs__items p-text--small-caps">
            <li class="p-breadcrumbs__item">
              <a tal:attributes="href view/context/distribution/fmt:url" tal:content="context/distribution/displayname">Distribution</a>
            </li>
            <li class="p-breadcrumbs__item">
              <span tal:content="context/displayname">Series</span>
            </li>
          </ol>
        </nav>
      </div>
    </tal:breadcrumbs>
    <section class="p-section" metal:fill-slot="main">
      <div tal:replace="structure context/@@+vanilla-distroseries-summary" />
      <section class="p-section">
        <div class="grid-row">
          <hr class="p-rule" />
          <h3>Packages</h3>
          <div class="grid-col-2 grid-col-medium-8">
            <div tal:replace="structure context/@@+vanilla-distroseries-packages-chart" />
          </div>
          <div class="grid-col-6 grid-col-medium-8">
            <div tal:replace="structure context/@@+vanilla-distroseries-packages-list" />
          </div>
        </div>
      </section>
    </section>
  </body>
</html>
